# --- Required ---

# OpenAI — used for meal parsing, recipe generation, suggestions
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# --- Auth (Discord OAuth) ---
# Required if deployed publicly. Locally you can skip these and bypass auth
# by directly opening the app — but APIs will reject without a session.
#
# Get from https://discord.com/developers/applications → your app → OAuth2
# Redirect URI must match exactly: https://YOUR-DOMAIN/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://YOUR-DOMAIN/auth/discord/callback

# Random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Comma-separated list of Discord user IDs allowed to log in.
# Get yours via Discord → Settings → Advanced → enable Developer Mode,
# then right-click your name → Copy User ID.
ALLOWED_DISCORD_IDS=

# --- Optional but recommended (better food matching) ---

# USDA FoodData Central — free, signup at https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# FatSecret Platform API — free 5k calls/day, https://platform.fatsecret.com/api/
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# --- Server ---

# Port to listen on (default 3000)
PORT=3000

# --- AI safety caps ---

# Hard cap on AI tokens per day (across all users). Past this, AI endpoints refuse calls.
DAILY_TOKEN_CAP=500000

# Hard cap on AI cost per day in USD (across all users).
DAILY_COST_CAP_USD=2

# Set to 1 to disable AI entirely (manual entry + saved foods still work).
AI_DISABLED=0
